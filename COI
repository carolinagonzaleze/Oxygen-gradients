#!/bin/bash
make.contigs(file=stabilityallF.files, deltaq=10, insert=30, trimoverlap=F, processors=40)
summary.seqs(fasta=current, count=current)
screen.seqs(fasta=current, count=current, maxambig=0, maxhomop=10, contigsreport=current)
summary.seqs(fasta=current, count=current)
screen.seqs(fasta=current, count=current, minlength=250)
summary.seqs(fasta=current, count=current)
align.seqs(candidate=current, template=output_auto.fasta)
unique.seqs(fasta=current, count=current)
summary.seqs(fasta=current, count=current)
chimera.vsearch(fasta=current, count=current, dereplicate=f)
summary.seqs(fasta=current, count=current)
classify.seqs(fasta=current, template=ref.fasta, taxonomy=ref.txt)
summary.seqs(fasta=current, count=current)
screen.seqs(fasta=current, count=current, taxonomy=current, minlength=250)
get.lineage(taxonomy=current, taxon=Animalia;, fasta=current, count=current)
cluster(fasta=current, cutoff=0.05, method=agc, count=current, processors=2)
get.oturep(fasta=current, list=current, count=current, method=abundance, processors=40)
classify.seqs(fasta=current, template=ref.fasta, taxonomy=ref.txt)
count.seqs(count=current, compress=f)
make.shared(count=current)
rarefaction.single(shared=current, calc=sobs-chao-shannon, iters=1000)
get.lineage(fasta=stabilityallF.trim.contigs.good.good.unique.denovo.vsearch.good.pick.agc.0.05.rep.fasta, count=stabilityallF.trim.contigs.good.good.unique.denovo.vsearch.good.pick.agc.0.05.rep.full.count_table, taxonomy=stabilityallF.trim.contigs.good.good.unique.denovo.vsearch.good.pick.agc.0.05.rep.ref.wang.taxonomy, processors=30, taxon=Animalia_EXT;)
sub.sample(fasta=current, count=current, taxonomy=current)
count.seqs(count=current, compress=f)
quit()
