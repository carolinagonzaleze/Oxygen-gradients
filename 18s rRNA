##Run in mothur ver. 1.43
##make the contigs based in the Forward and reverse files for each sample. Trim to the overlapping region (since it is about 130 bp is covered totally for both F & R), only keep inserts if Q>30, and if there is a disagreement between F&R, keep as ambiguous unless the difference between both Q > 10
make.contigs(file=stabilityF.files, deltaq=10, insert=30, trimoverlap=T, processors=60)
summary.seqs(fasta=current, count=current)
##remove all contigs with any ambiguity, and those with more than 10 homopolymers
screen.seqs(fasta=current, count=current, maxambig=0, maxhomop=10, contigsreport=current)
summary.seqs(fasta=current, count=current)
##remove all seqs with lenght < 115
screen.seqs(fasta=current, count=current, minlength=115)
##Align using as template SILVA 128 (V9 region only)
align.seqs(candidate=current, template=Silva128_ShortAll.fas)
summary.seqs(fasta=current, count=current)
get.current()
##you can check here the alignment to see if there are any primers left - should not be the case with V9 and trimoverlap = T in the early steps)
##remove tails that were kept (likely leftover primers)
pcr.seqs(fasta=current, count=current, start=1, end=692, keepdots=false)
##remove all contigs that do not reach the end of the fragment
screen.seqs(fasta=current, count=current, end=692)
summary.seqs(fasta=current, count=current)
##remove all contigs that do not start at the beginning of the fragment
screen.seqs(fasta=current, count=current, start=1)
summary.seqs(fasta=current, count=current)
##remove all seqs with lenght < 115 (if created during removal of tails)
screen.seqs(fasta=current, count=current, minlength=115)
summary.seqs(fasta=current, count=current)
##create uniques
unique.seqs(fasta=current, count=current)
summary.seqs(fasta=current, count=current)
##removal of chimeras
chimera.vsearch(fasta=current, count=current, dereplicate=f)
summary.seqs(fasta=current, count=current)
##removal of PCR errors using UNOISE
pre.cluster(fasta=current, count=current, diffs=1, method=unoise)
summary.seqs(fasta=current, count=current)
degap.seqs(fasta=current, count=current)

##Classify against MZG database
classify.seqs(fasta=current, template=Silva128_ShortAll.ng.fasta, taxonomy=taxmap_slv_ssu_ref_128_ShortAll.txt, count=current)
#optative: select now only metazoans
#get.lineage(fasta=current, taxonomy=Vcurrent, count=current, taxon=Eukaryota;opistokontha;metazoa;)
#let's get some stats: S, Shannon, Chao. DO NOT REMOVE SINGLETONS, since then Chao is just S.
count.seqs(count=current, compress=F)
count.seqs(count=current, compress=t)
make.shared(count=current)
rarefaction.single(shared=current, calc=sobs-chao-shannon, iters=1000)
get.lineage(fasta=current, count=current, taxonomy=current, taxon=Metazoa_(Animalia);)
sub.sample(fasta=current, count=current, taxonomy=current)
count.seqs(count=current, compress=f)

quit()

quit()
